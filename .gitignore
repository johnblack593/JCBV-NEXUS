# ── NEXUS v5.0 Gitignore ────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Runtime databases (never committed)
*.db
*.sqlite
*.sqlite3

# Logs and reports (generated at runtime)
nexus/logs/
nexus/reports/
nexus/data/
data/journal/

# ML model artifacts (too large for git; use git-lfs or object storage)
nexus/models/
*.pkl
*.joblib
*.h5
*.keras

# IDE and tooling
.vscode/settings.json
.idea/
.pyre_configuration
.DS_Store

# Environment secrets (CRITICAL: never commit API keys)
.env
.env.*
#!.env.example

# OS Metadata
Thumbs.db
desktop.ini

# Docker local artifacts
.docker_cache/

# Other
*.swp
*.swo
*$py.class
*.onnx
*.log
*.log.*
logs/
