    {
      "title": "📊 Win Rate (%)",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nexus_win_rate_pct",
          "legendFormat": "Win Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 58 }
            ]
          }
        }
      }
    },
    {
      "title": "📉 Drawdown Actual (%)",
      "type": "gauge",
