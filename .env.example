# ── IQ Option (Legacy / Phase 1) ───────────────────────────────
IQ_OPTION_EMAIL=your_email_here
IQ_OPTION_PASSWORD=your_password_here
IQ_OPTION_ACCOUNT_TYPE=PRACTICE
IQ_MIN_PAYOUT=80

# ── Bitget (Phase 3) ────────────────────────────────────────────
BITGET_API_KEY=your_bitget_api_key_here
BITGET_SECRET=your_bitget_secret_here
BITGET_PASSPHRASE=your_bitget_passphrase_here
BITGET_MODE=futures           # futures | spot | both
BITGET_LEVERAGE=5             # 1-10 (hard cap: 10, default: 5)
BITGET_SANDBOX=True           # ALWAYS True until live-ready

# ── Session Control ─────────────────────────────────────────────
ACTIVE_SESSIONS=IQ_OPTION     # IQ_OPTION | BITGET | IQ_OPTION,BITGET

# ── Position Manager ─────────────────────────────────────────────
BITGET_BREAKEVEN_PCT=1.0      # % gain to trigger breakeven SL move
BITGET_TRAIL_ATR_MULT=1.5     # ATR multiplier for trailing stop dist
BITGET_PARTIAL_T1_ATR=2.0     # ATR multiples gain to fire T1 close
BITGET_PARTIAL_T2_ATR=4.0     # ATR multiples gain to fire T2 close
BITGET_HTF_FILTER=False       # Enable 4h trend filter (experimental)
BITGET_POSITION_TICK=15       # Position manager tick interval (seconds)
