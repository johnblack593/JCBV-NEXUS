# ═══════════════════════════════════════════════════════════════════
# NEXUS v5.0 — Variables de Entorno
# ═══════════════════════════════════════════════════════════════════
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio (ya está en .gitignore).
# ═══════════════════════════════════════════════════════════════════


# ── CONTROL DE EJECUCIÓN ────────────────────────────────────────────

# Exchange activo. Opciones: IQ_OPTION | BITGET
EXECUTION_VENUE=BITGET

# Estrategia activa. Opciones: BINARY_ML | BITGET_TREND_SCALPER
ACTIVE_STRATEGY=BITGET_TREND_SCALPER

# Sesiones activas. Opciones: IQ_OPTION | BITGET | IQ_OPTION,BITGET
ACTIVE_SESSIONS=BITGET

# Modo simulación. True = no se ejecutan órdenes reales en el exchange.
# SIEMPRE arranca en True. Cambia a False solo cuando estés listo para live.
DRY_RUN=True


# ── IQ OPTION ───────────────────────────────────────────────────────
# Credenciales de tu cuenta IQ Option.
# Solo necesarias si EXECUTION_VENUE=IQ_OPTION.

IQ_OPTION_EMAIL=tu_email@ejemplo.com
IQ_OPTION_PASSWORD=tu_contraseña_aqui

# Tipo de cuenta. PRACTICE = cuenta demo. REAL = dinero real.
# Usa PRACTICE hasta que el sistema esté validado en producción.
IQ_OPTION_ACCOUNT_TYPE=PRACTICE

# Payout mínimo para aceptar una operación (porcentaje).
# Operaciones con payout menor a este valor son ignoradas.
MIN_PAYOUT=80

# Umbrales mínimos de confianza por régimen macro.
# Estos valores garantizan que bajo estrés del mercado solo tomemos
# señales de altísima certeza.
MIN_CONFIDENCE_GREEN=0.55
MIN_CONFIDENCE_YELLOW=0.65
MIN_CONFIDENCE_RED=0.75


# ── BITGET ──────────────────────────────────────────────────────────
# Credenciales de la API de Bitget.
# Crear la API en: Bitget → Perfil → API Management → Crear API.
# Permisos necesarios: Lectura + Operaciones de Futuros.
# NO habilites permisos de retiro en la API.

BITGET_API_KEY=tu_api_key_aqui
BITGET_API_SECRET=tu_api_secret_aqui

# Passphrase: la frase que pusiste al crear la API en Bitget.
BITGET_API_PASSPHRASE=tu_passphrase_aqui

# Modo de operación y entorno de pruebas
BITGET_MODE=futures
BITGET_SANDBOX=True
BITGET_DEMO_MODE=true


# ── SIZING DE POSICIONES (MODELO DÓLAR-RIESGO) ──────────────────────
# Este modelo permite que siempre pienses en dólares.
# El sistema calcula automáticamente el tamaño en contratos.
#
# Fórmula interna:
#   notional = balance × BITGET_RISK_PCT_PER_TRADE × BITGET_LEVERAGE
#   contratos = notional / precio_actual
#
# Ejemplo con balance=$100, riesgo=1%, leverage=5x, BTC=$84000:
#   notional = $100 × 0.01 × 5 = $5
#   contratos = $5 / $84000 = 0.0000595 BTC

# Porcentaje del balance a arriesgar por operación. 0.01 = 1%.
# Recomendado para paper trading: 0.01 (1%). Nunca subas de 0.02 en live.
BITGET_RISK_PCT_PER_TRADE=0.01

# Apalancamiento. Debe coincidir con el leverage configurado en tu cuenta Bitget.
# Valor conservador para empezar: 5. No usar más de 10.
BITGET_LEVERAGE=5

# Notional mínimo en USDT. Órdenes por debajo de este valor son ignoradas.
# El mínimo de Bitget en futuros es típicamente $5 USDT.
BITGET_MIN_ORDER_USDT=5.0

# Notional máximo en USDT por operación. Límite duro sin importar el balance.
# Durante paper trading mantén este valor en $50 o menos.
BITGET_MAX_SIZE_USDT=50.0


# ── POSITION MANAGER (GESTIÓN ACTIVA DE POSICIONES) ─────────────────
# Controla el trailing stop, breakeven y cierres parciales automáticos.

# Porcentaje de ganancia para mover el SL a breakeven (punto de entrada).
# Ejemplo: 1.0 = cuando la posición gana 1%, el SL se mueve al precio de entrada.
BITGET_BREAKEVEN_PCT=1.0

# Multiplicador ATR para la distancia del trailing stop.
# Ejemplo: 1.5 = el stop sigue el precio a una distancia de 1.5x el ATR.
BITGET_TRAIL_ATR_MULT=1.5

# ATR mínimo de ganancia para ejecutar el cierre parcial Tier 1 (40% de la posición).
BITGET_PARTIAL_T1_ATR=2.0

# ATR mínimo de ganancia para ejecutar el cierre parcial Tier 2 (35% de la posición).
BITGET_PARTIAL_T2_ATR=4.0

# Filtro de tendencia en timeframe alto (4h). Experimental — deja en False por ahora.
BITGET_HTF_FILTER=False

# Intervalo en segundos del loop del PositionManager.
# Cada cuántos segundos revisa si hay que mover el stop o cerrar parcialmente.
BITGET_POSITION_TICK=15


# ── TELEGRAM ────────────────────────────────────────────────────────
# Canal de alertas en tiempo real. NEXUS envía notificaciones de:
#   - Inicio y cierre del sistema
#   - Cambios de régimen macro (VERDE/AMARILLO/ROJO)
#   - Cada trade ejecutado (entrada y resultado)
#   - Circuit breaker activado
#   - Errores críticos del sistema
#   - Reporte semanal automático
#
# Cómo obtener el token:
#   1. Abre Telegram y busca @BotFather
#   2. Envía /newbot y sigue las instrucciones
#   3. BotFather te dará el token (formato: 123456789:AAF...)
#
# Cómo obtener tu Chat ID:
#   1. Envía un mensaje a tu bot
#   2. Abre en el navegador:
#      https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   3. Busca el campo "chat" → "id" en la respuesta JSON

# Token del bot (lo da @BotFather al crear el bot).
TELEGRAM_BOT_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del chat principal donde se envían todas las alertas.
# Puede ser tu chat personal con el bot o un grupo.
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ID del chat de desarrollo (opcional). Para alertas técnicas internas.
# Puede ser el mismo que TELEGRAM_CHAT_ID si no tienes un canal separado.
TELEGRAM_DEV_CHAT_ID=tu_dev_chat_id_aqui


# ── REDIS ────────────────────────────────────────────────────────────
# Bus de estado compartido entre módulos de NEXUS.
# Redis guarda: régimen macro, configuración en tiempo real (OCP),
# modo AI, mejores activos (OpportunityAgent), kill switch (PANIC_MODE).
#
# Si no tienes Redis corriendo, NEXUS opera igual pero sin:
#   - Panel de control OCP (overrides en tiempo real)
#   - Caché de activos del OpportunityAgent
#   - Kill switch remoto
#
# Instalación rápida con Docker:
#   docker run -d -p 6379:6379 redis:alpine

REDIS_HOST=localhost
REDIS_PORT=6379

# Contraseña de Redis. Déjalo vacío si tu Redis local no tiene contraseña.
REDIS_PASSWORD=


# ── LLM (ANÁLISIS MACRO CON INTELIGENCIA ARTIFICIAL) ────────────────
# NEXUS usa modelos de lenguaje para analizar el régimen macro del
# mercado (VERDE/AMARILLO/ROJO) y tomar mejores decisiones de trading.
#
# El sistema tiene rotación automática de claves: si una clave agota
# su límite diario de tokens, el sistema pasa a la siguiente
# automáticamente sin detener el pipeline.
#
# Si NO configuras ninguna clave LLM, NEXUS funciona igual pero
# el análisis macro usará solo heurísticas (sin IA).
#
# ── GROQ (Primario — menor latencia, gratuito) ──────────────────────
# Groq ofrece cuentas gratuitas con límite diario de tokens.
# Puedes crear varias cuentas con diferentes correos y poner
# todas las claves aquí separadas por coma.
#
# Cómo obtener una clave Groq GRATIS:
#   1. Ve a https://console.groq.com
#   2. Crea una cuenta (puedes usar Gmail)
#   3. Ve a "API Keys" → "Create API Key"
#   4. Copia la clave (empieza con "gsk_...")
#
# Puedes poner múltiples claves separadas por coma (sin espacios):
#   GROQ_API_KEYS=gsk_clave1,gsk_clave2,gsk_clave3

GROQ_API_KEYS=gsk_tu_clave_groq_aqui

# Modelo de Groq a usar. Recomendado: llama3-70b-8192 (gratis y potente).
# Alternativa más rápida: llama3-8b-8192
GROQ_MODEL=llama-3.3-70b-versatile

# ── GEMINI (Fallback — gratuito con límite generoso) ─────────────────
# Google Gemini se usa como respaldo cuando Groq no está disponible.
# También soporta múltiples claves separadas por coma.
#
# Cómo obtener una clave Gemini GRATIS:
#   1. Ve a https://aistudio.google.com/app/apikey
#   2. Inicia sesión con tu cuenta de Google
#   3. Clic en "Create API Key"
#   4. Copia la clave (empieza con "AIza...")
#
# Múltiples claves separadas por coma:
#   GEMINI_API_KEYS=AIzaKey1,AIzaKey2

GEMINI_API_KEYS=AIza_tu_clave_gemini_aqui

# Modelo de Gemini a usar. Recomendado: gemini-1.5-flash (rápido y gratis).
GEMINI_MODEL=gemini-1.5-flash

# Segundos de cooldown cuando una clave agota su límite diario.
# Por defecto: 3600 (1 hora). El sistema intentará la siguiente
# clave disponible antes de esperar el cooldown.
LLM_COOLDOWN_SECONDS=3600


# ── QUESTDB (DATA LAKE) ──────────────────────────────────────────────
# Base de datos de series de tiempo para persistir todos los trades,
# candles y métricas del sistema. Usada para análisis post-sesión.
#
# Si no tienes QuestDB, NEXUS opera igual pero los trades no se persisten
# en disco para análisis histórico.
#
# Instalación rápida con Docker:
#   docker run -d -p 9000:9000 -p 8812:8812 questdb/questdb

QUESTDB_HOST=localhost

# Puerto ILP (line protocol) para escritura rápida de series de tiempo.
QUESTDB_ILP_PORT=9009

# Puerto HTTP para consultas SQL.
QUESTDB_HTTP_PORT=9000


# ── OBSERVABILIDAD (PROMETHEUS) ──────────────────────────────────────
# Métricas del sistema expuestas en formato Prometheus para Grafana.
# NEXUS expone: trades diarios, latencia, confidence, P&L, circuit breaker.
#
# Si no tienes Grafana/Prometheus, este puerto simplemente queda
# inactivo — no afecta el funcionamiento del sistema.

# Puerto donde NEXUS expone las métricas Prometheus.
PROMETHEUS_PORT=9090


# ── LOGGING ─────────────────────────────────────────────────────────
# Nivel de detalle de los logs del sistema.
# Opciones: DEBUG | INFO | WARNING | ERROR
# Usa DEBUG durante desarrollo y paper trading para máxima visibilidad.
# Usa INFO en producción para reducir ruido.
LOG_LEVEL=INFO
