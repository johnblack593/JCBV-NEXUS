# ═══════════════════════════════════════════════════════════════
# NEXUS v5.0 (beta) — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Execution Venue ───────────────────────────────────────────
# Active trading venue. Supported: IQ_OPTION
# (BITGET will be added in Phase 3)
EXECUTION_VENUE=IQ_OPTION

# ── Active Strategy ───────────────────────────────────────────
# Must match a key in NexusPipeline._STRATEGY_REGISTRY
# Currently available: BINARY_ML
ACTIVE_STRATEGY=BINARY_ML

# ── Dry Run Mode ──────────────────────────────────────────────
# Set to True for paper trading. No real orders are placed.
# ALWAYS start with True. Switch to False only after Phase 5 validation.
DRY_RUN=True

# ── IQ Option Credentials ─────────────────────────────────────
IQ_EMAIL=your_email@example.com
IQ_PASSWORD=your_secure_password
IQ_ACCOUNT_TYPE=PRACTICE  # PRACTICE | REAL

# ── LLM Providers (Groq + Gemini) ────────────────────────────
# Both providers are optional individually; at least one must be set.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# LLM model selection (defaults shown)
GROQ_MODEL=llama3-70b-8192
GEMINI_MODEL=gemini-1.5-flash

# ── Telegram Reporter ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=xxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── QuestDB (Data Lake) ───────────────────────────────────────
QUESTDB_HOST=localhost
QUESTDB_PORT=9000

# ── Risk Parameters ───────────────────────────────────────────
# These can be overridden at runtime via Redis OCP keys
IQ_BASE_SIZE_USD=1.0
IQ_MAX_DAILY_TRADES=3
IQ_MIN_CONFIDENCE=0.55
IQ_MIN_PAYOUT_PCT=80
IQ_COOLDOWN_SECONDS=300

# ── Consensus Engine ─────────────────────────
MIN_CONFIDENCE_GREEN=0.55
MIN_CONFIDENCE_YELLOW=0.62
ATR_FLOOR=0.00005
